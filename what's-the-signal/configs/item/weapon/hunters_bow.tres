rarity = 2
modifiers = Array[ExtResource("2")]([SubResource("Mod_Dmg_Rare")])
abilities = Array[ExtResource("4")]([ExtResource("5"), ExtResource("6")])

[sub_resource type="Resource" id="Mod_Dmg_Epic"]
