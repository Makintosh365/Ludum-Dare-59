[gd_resource type="Resource" script_class="Artifact" format=3]

[ext_resource type="Script" path="res://scripts/units/artifact.gd" id="1"]
[ext_resource type="Script" path="res://scripts/units/stat_modifier.gd" id="2"]
[ext_resource type="Script" path="res://scripts/units/artifact_variant.gd" id="3"]
[ext_resource type="Script" path="res://scripts/units/ability.gd" id="4"]
