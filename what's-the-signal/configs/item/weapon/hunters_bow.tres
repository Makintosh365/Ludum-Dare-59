kind = 1
value = 2.0

[sub_resource type="Resource" id="Variant_Common"]
script = ExtResource("3")
rarity = 0
modifiers = Array[ExtResource("2")]([SubResource("Mod_Dmg_Common")])

[sub_resource type="Resource" id="Mod_Dmg_Uncommon"]
